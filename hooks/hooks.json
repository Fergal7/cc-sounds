{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-WindowStyle",
              "Hidden",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/scripts/play-if-background.ps1",
              "Stop",
              "Alarm09.wav",
              "0"
            ]
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-WindowStyle",
              "Hidden",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/scripts/play-if-background.ps1",
              "StopFailure",
              "Ring02.wav",
              "0"
            ]
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-WindowStyle",
              "Hidden",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/scripts/play-if-background.ps1",
              "PermissionRequest",
              "Alarm04.wav",
              "2000"
            ]
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-NonInteractive",
              "-WindowStyle",
              "Hidden",
              "-File",
              "${CLAUDE_PLUGIN_ROOT}/scripts/play-if-background.ps1",
              "Elicitation",
              "Alarm04.wav",
              "2000"
            ]
          }
        ]
      }
    ]
  }
}
